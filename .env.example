# Environment Configuration Template

# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=password_vault

# Security Settings
# PBKDF2 iterations: 260000 (recommended by OWASP)
PBKDF2_ITERATIONS=260000
SALT_LENGTH=32

# Account Security
LOGIN_ATTEMPT_LIMIT=5
LOGIN_LOCK_DURATION=10

# Application Settings
APP_DEBUG=False
LOG_LEVEL=INFO

# Feature Flags
ENABLE_AUDIT_LOGGING=True
ENABLE_PASSWORD_EXPORT=False
